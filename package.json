    "clean": "rm -rf dist",
    "dev": "tsc --watch"
  },
  "keywords": [
    "agents",
    "ai",
    "llm",
    "agentic",
    "framework",
    "skills",
    "markdown",
    "agents-eco",
    "open-source"
  ],
  "license": "MIT",
  "author": "agents.eco",
  "homepage": "https://agents.eco",
  "repository": {
    "type": "git",
    "url": "https://github.com/agents-eco/open-agentic-framework"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  }
}
